# Quantara environment configuration
# Copy to .env (local) — production secrets live in Lovable Cloud settings.

# Provisioned by Lovable. Do not set manually.
# LOVABLE_API_KEY=

# HMAC secret for /api/public/webhook signature verification.
WEBHOOK_SECRET=change-me

# Encrypted session cookie key (used by @tanstack/react-start/server sessions).
SESSION_SECRET=change-me-32-chars-minimum-please
